# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/openbusinesschat?schema=public"

# Auth
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# OpenAI / LLM Provider
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# Alternative providers (set LLM_PROVIDER to switch)
# LLM_PROVIDER="openai" | "anthropic" | "groq" | "ollama"
LLM_PROVIDER="openai"

# Anthropic (optional)
# ANTHROPIC_API_KEY="sk-ant-..."
# ANTHROPIC_MODEL="claude-3-5-sonnet-20241022"

# Groq (optional)
# GROQ_API_KEY="gsk_..."
# GROQ_MODEL="llama-3.1-8b-instant"

# Ollama (optional local)
# OLLAMA_BASE_URL="http://localhost:11434"
# OLLAMA_MODEL="llama3.2"

# App
APP_URL="http://localhost:3000"
MAX_FILE_SIZE_MB="10"

# File storage (local by default)
UPLOAD_DIR="./uploads"
