# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/openbusinesschat?schema=public"

# Auth
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
# 32-byte base64 or 64-character hex key. Generate with: openssl rand -base64 32
# Required before saving encrypted workspace provider keys or tool headers.
WORKSPACE_SECRETS_KEY=""
# Optional distinct salt for privacy-preserving audit/event identifiers.
AUDIT_HASH_SALT=""
GOOGLE_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"

# OpenAI / LLM Provider
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# Provider selection
# LLM_PROVIDER="openai" | "anthropic" | "gemini" | "groq" | "ollama"
LLM_PROVIDER="openai"
LLM_FALLBACK_PROVIDER=""

# Anthropic (optional)
# ANTHROPIC_API_KEY="sk-ant-..."
# ANTHROPIC_MODEL="claude-3-5-sonnet-20241022"

# Groq (optional)
# GROQ_API_KEY="gsk_..."
# GROQ_MODEL="llama-3.1-8b-instant"

# Google Gemini (optional; OpenAI remains required for embeddings)
# GEMINI_API_KEY="..."
# GEMINI_MODEL="gemini-2.0-flash"

# Ollama (optional local)
# OLLAMA_BASE_URL="http://localhost:11434"
# OLLAMA_MODEL="llama3.2"

# App
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
MAX_FILE_SIZE_MB="10"
# Private uploads. Development uses .data/uploads when the bucket is omitted.
# Production must configure an S3-compatible private bucket.
OBJECT_STORAGE_BUCKET=""
OBJECT_STORAGE_REGION="auto"
OBJECT_STORAGE_ENDPOINT=""
OBJECT_STORAGE_ACCESS_KEY_ID=""
OBJECT_STORAGE_SECRET_ACCESS_KEY=""
OBJECT_STORAGE_FORCE_PATH_STYLE="false"
# Local scanned-PDF OCR (first 10 pages). Language packs use Tesseract codes.
OCR_LANGUAGES="eng"
# Optional self-hosted Tesseract trained-data base URL; document content is never sent there.
OCR_LANGUAGE_DATA_URL=""

# Optional distributed rate limiting. Without Upstash, the app uses a bounded
# per-instance limiter so self-hosted and preview deployments remain functional.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
RATE_LIMIT_REQUIRE_DISTRIBUTED="false"

# Public chat abuse protection
PUBLIC_CHAT_RATE_LIMIT_REQUESTS="30"
PUBLIC_CHAT_RATE_LIMIT_WINDOW_SECONDS="60"

# If true, chat remains available when a configured Redis service is down.
RATE_LIMIT_FAIL_OPEN="false"

# One-time platform administrator bootstrap. Never commit a real password.
# Run npm run admin:bootstrap after migrations, then remove the password value.
PLATFORM_ADMIN_USERNAME="admin"
PLATFORM_ADMIN_EMAIL="admin@localhost"
PLATFORM_ADMIN_INITIAL_PASSWORD=""
INGESTION_WORKER_SECRET=""
# Optional distinct credentials for retryable webhook delivery and retention/privacy jobs.
# If omitted, both workers fall back to INGESTION_WORKER_SECRET.
WEBHOOK_WORKER_SECRET=""
MAINTENANCE_WORKER_SECRET=""
