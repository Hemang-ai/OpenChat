generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String?
  name          String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  workspaces    Workspace[]
  oauthAccounts OAuthAccount[]
}

model OAuthAccount {
  id                String   @id @default(cuid())
  provider          String
  providerAccountId String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Workspace {
  id                   String   @id @default(cuid())
  name                 String
  slug                 String   @unique
  description          String?
  // Per-workspace AI configuration (each business uses its own keys)
  llmProvider          String? // primary: "openai" | "anthropic" | "groq" | "ollama" | "gemini"
  fallbackLlmProvider  String? // used if primary chat call fails
  openaiApiKey         String?
  openaiModel          String?
  openaiEmbeddingModel String?
  anthropicApiKey      String?
  anthropicModel       String?
  groqApiKey           String?
  groqModel            String?
  ollamaBaseUrl        String?
  ollamaModel          String?
  geminiApiKey         String?
  geminiModel          String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  ownerId              String
  owner                User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  bots                 Bot[]
}

model Bot {
  id                          String            @id @default(cuid())
  name                        String
  description                 String?
  publicKey                   String            @unique @default(cuid())
  welcomeMessage              String            @default("Hello! How can I help you today?")
  systemPrompt                String?
  businessContext             String?
  tone                        String            @default("professional")
  strictness                  String            @default("strict") // "strict" | "balanced" | "flexible"
  fallbackBehavior            String            @default("contact") // "contact" | "general_knowledge" | "ask_clarify"
  contactInfo                 String? // shown when bot can't answer
  leadCaptureEnabled          Boolean           @default(false)
  leadCapturePrompt           String            @default("Want us to follow up? Leave your details and our team will reach out.")
  suggestedQuestions          Json? // cached starter questions auto-generated from knowledge
  suggestedQuestionsUpdatedAt DateTime?
  isActive                    Boolean           @default(true)
  createdAt                   DateTime          @default(now())
  updatedAt                   DateTime          @updatedAt
  workspaceId                 String
  workspace                   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  knowledgeSources            KnowledgeSource[]
  conversations               Conversation[]
  leads                       Lead[]
  tools                       Tool[]
}

model KnowledgeSource {
  id           String          @id @default(cuid())
  type         SourceType
  name         String
  url          String?
  filePath     String?
  mimeType     String?
  fileSize     Int?
  status       IngestionStatus @default(PENDING)
  errorMessage String?
  metadata     Json?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  botId        String
  bot          Bot             @relation(fields: [botId], references: [id], onDelete: Cascade)
  documents    Document[]
}

model Document {
  id                String          @id @default(cuid())
  title             String?
  content           String
  createdAt         DateTime        @default(now())
  knowledgeSourceId String
  knowledgeSource   KnowledgeSource @relation(fields: [knowledgeSourceId], references: [id], onDelete: Cascade)
  chunks            DocumentChunk[]
}

model DocumentChunk {
  id         String   @id @default(cuid())
  content    String
  chunkIndex Int
  embedding  String?
  metadata   Json?
  createdAt  DateTime @default(now())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model Conversation {
  id        String    @id @default(cuid())
  sessionId String    @unique @default(cuid())
  botId     String
  bot       Bot       @relation(fields: [botId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]
  leads     Lead[]
  toolExecutions ToolExecution[]
  userAgent String?
  ipAddress String?
}

model Message {
  id             String       @id @default(cuid())
  role           MessageRole
  content        String
  isGrounded     Boolean?
  isRefused      Boolean?
  sourceChunkIds String[]
  createdAt      DateTime     @default(now())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Lead {
  id             String        @id @default(cuid())
  name           String?
  email          String
  phone          String?
  company        String?
  message        String?
  status         LeadStatus    @default(NEW)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  botId          String
  bot            Bot           @relation(fields: [botId], references: [id], onDelete: Cascade)
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([botId, status])
  @@index([conversationId])
}

enum SourceType {
  FILE
  WEBSITE
  YOUTUBE
  MANUAL
  GOOGLE_DRIVE
}

enum IngestionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum MessageRole {
  USER
  ASSISTANT
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  DISMISSED
}

// ============================================================================
// Agentic actions — Tools + Tool execution log
// ============================================================================

model Tool {
  id            String           @id @default(cuid())
  botId         String
  bot           Bot              @relation(fields: [botId], references: [id], onDelete: Cascade)
  name          String           // function name exposed to the LLM (snake_case)
  description   String           // shown to LLM so it knows when to use the tool
  // JSON Schema describing the tool's input parameters (OpenAI-compatible)
  inputSchema   Json
  kind          ToolKind         @default(HTTP_REQUEST)
  // HTTP-specific config (kind = HTTP_REQUEST)
  method        String?          @default("POST") // GET / POST / PUT / PATCH / DELETE
  endpoint      String?          // URL with optional {placeholders} for inputs
  headers       Json?            // map of static request headers (include auth)
  // Approval gating: AUTO runs immediately; REQUIRE_CONFIRM surfaces for user approval
  approvalMode  ToolApprovalMode @default(AUTO)
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  executions    ToolExecution[]

  @@index([botId])
}

model ToolExecution {
  id             String              @id @default(cuid())
  toolId         String
  tool           Tool                @relation(fields: [toolId], references: [id], onDelete: Cascade)
  conversationId String?
  conversation   Conversation?       @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  input          Json
  output         Json?
  errorMessage   String?
  status         ToolExecutionStatus @default(SUCCESS)
  latencyMs      Int?
  createdAt      DateTime            @default(now())

  @@index([toolId])
  @@index([conversationId])
}

enum ToolKind {
  HTTP_REQUEST  // generic outbound HTTP call (covers 90% of integrations)
  BUILTIN       // reserved for first-party integrations later (e.g. send_email)
}

enum ToolApprovalMode {
  AUTO            // run immediately when LLM requests it
  REQUIRE_CONFIRM // pause and ask the user (preview UI flag)
}

enum ToolExecutionStatus {
  SUCCESS
  ERROR
  PENDING_APPROVAL
  REJECTED
}
